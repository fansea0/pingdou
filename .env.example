# 站点统计管理员密码（必填，至少 6 位）
# 设置后访问 /statics 时需输入此密码
STATICS_PASSWORD=replace-with-your-secret-password

# 服务端口（可选，默认 3000）
PORT=3000

# IP 哈希盐（可选，未设置则启动时自动生成随机盐）
# 同一盐下不同 IP 哈希稳定，便于跨重启跟踪 UV
# IP_HASH_SALT=your-fixed-salt

# SQLite 文件路径（可选，默认 data/stats.db）
# STATS_DB_PATH=./data/stats.db

# 生产环境标记（影响 cookie secure 属性）
NODE_ENV=production